enter inside sail container to run artisan commands
./vendor/bin/sail exec laravel.test bash


enter inside mysql bash to enter inside mysql bash 

./vendor/bin/sail exec mysql bash

then enter inside mysql with this command
mysql -u sail -p rarecare


# Start in foreground
./vendor/bin/sail up

# Start in background (detached)
./vendor/bin/sail up -d

# Stop Sail
./vendor/bin/sail down